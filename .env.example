# ── Supabase ──────────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Usado pelo cron para enviar push a todos os usuários. NUNCA expor no client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL pública do app, usada no link do e-mail de recuperação de senha.
# Em dev cai em http://localhost:3000 se não definida. Em produção, a URL da Vercel.
# Também precisa estar em Supabase → Authentication → URL Configuration (Redirect URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Web Push (VAPID) ──────────────────────────────────────────────────────
# Gere uma vez com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:voce@exemplo.com

# ── Cron ──────────────────────────────────────────────────────────────────
# Segredo que protege /api/cron/notifications. A Vercel envia como Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=uma-string-aleatoria-bem-longa
